[general]
"common/gitconfig" = "$HOME/.gitconfig"
"common/rust/config.toml" = "$HOME/.cargo/config.toml"
"common/pi/settings.json" = "$HOME/.pi/agent/settings.json"
"common/pi/skills" = "$HOME/.pi/agent/skills"

[windows]
# Prompt
"windows/shell/Microsoft.PowerShell_profile.ps1" = "$HOME/Documents/WindowsPowerShell/Microsoft.PowerShell_profile.ps1"
# Terminal
"windows/terminal/settings.json" = "$APPDATA/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json"
# Zed
"common/zed/settings.json" = "$APPDATA/Zed/settings.json"
"common/zed/keymap.json" = "$APPDATA/Zed/keymap.json"

[linux]
# Fish
"linux/shell/config.fish" = "$HOME/.config/fish/config.fish"
"common/shell/aliases.fish" = "$HOME/.config/fish/aliases.fish"
"common/shell/fish_greeting.fish" = "$HOME/.config/fish/functions/fish_greeting.fish"
"common/shell/fork.fish" = "$HOME/.config/fish/functions/fork.fish"
"common/shell/esprs.fish" = "$HOME/.config/fish/functions/esprs.fish"
## Completions
"common/shell/espup.fish" = "$HOME/.config/fish/completions/espup.fish"
"common/shell/espflash.fish" ="$HOME/.config/fish/completions/espflash.fish"
# Terminal
"linux/alacritty.toml" = "$HOME/.config/alacritty/alacritty.toml"
# Zed
"common/zed/settings.json" = "$HOME/.config/zed/settings.json"
"common/zed/keymap.json" = "$HOME/.config/zed/keymap.json"
[darwin]
# Fish
"mac-os/shell/config.fish" = "$HOME/.config/fish/config.fish"
"common/shell/aliases.fish" = "$HOME/.config/fish/aliases.fish"
"common/shell/fish_greeting.fish" = "$HOME/.config/fish/functions/fish_greeting.fish"
"common/shell/fork.fish" = "$HOME/.config/fish/functions/fork.fish"
"common/shell/esprs.fish" = "$HOME/.config/fish/functions/esprs.fish"
## Completions
"common/shell/espup.fish" = "$HOME/.config/fish/completions/espup.fish"
"common/shell/espflash.fish" ="$HOME/.config/fish/completions/espflash.fish"
# Zed
"common/zed/settings.json" = "$HOME/.config/zed/settings.json"
"common/zed/keymap.json" = "$HOME/.config/zed/keymap.json"
